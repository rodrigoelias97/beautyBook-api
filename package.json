{
  "name": "beautybook-api",
  "version": "1.0.0",
  "description": "API REST simples do BeautyBook com Express e banco em memoria.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "mocha --file test/helpers/test-setup.js \"test/api/**/*.test.js\"",
    "test:api": "mocha --file test/helpers/test-setup.js \"test/api/**/*.test.js\"",
    "test:report": "mocha --file test/helpers/test-setup.js \"test/api/**/*.test.js\" --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=resultado-testes,quiet=true",
    "test:performance:smoke": "k6 run test/performance/tests/smoke.test.js",
    "test:performance:load": "k6 run test/performance/tests/load.test.js",
    "test:performance:stress": "k6 run test/performance/tests/stress.test.js",
    "test:performance:spike": "k6 run test/performance/tests/spike.test.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^5.2.0",
    "mocha": "^11.7.4",
    "mochawesome": "^7.1.3",
    "supertest": "^7.1.1"
  }
}
